{
  "name": "@rickydata/testing",
  "version": "0.1.1",
  "description": "Shared test harness for rickydata chat and voice agents — declarative test cases, validation pipelines, and mock helpers",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./chat": {
      "types": "./dist/chat.d.ts",
      "import": "./dist/chat.js",
      "require": "./dist/chat.cjs"
    },
    "./voice": {
      "types": "./dist/voice.d.ts",
      "import": "./dist/voice.js",
      "require": "./dist/voice.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/chat.ts src/voice.ts --format cjs,esm --dts --clean --external rickydata",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "rickydata": ">=1.2.0"
  },
  "devDependencies": {
    "rickydata": "*",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT"
}
