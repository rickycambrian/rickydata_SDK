{
  "name": "@rickydata/chat",
  "version": "0.1.0",
  "description": "Reusable floating chat bubble with wallet auth, SSE streaming, agent actions, and theming",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --external react --external react-dom --external rickydata --external @rickydata/react --external zustand",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0"
  },
  "peerDependencies": {
    "rickydata": ">=1.2.0",
    "@rickydata/react": ">=0.1.0",
    "zustand": ">=5.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@rickydata/react": "*",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rickydata": "*",
    "zustand": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "license": "MIT"
}
