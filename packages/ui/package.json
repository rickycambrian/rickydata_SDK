{
  "name": "@rickydata/ui",
  "version": "0.1.1",
  "description": "Reusable RickyData UI primitives and layout components",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rickycambrian/rickydata_SDK"
  },
  "homepage": "https://marketplace.rickydata.org",
  "scripts": {
    "build": "tsup src/index.tsx --format cjs,esm --dts --clean --external react --external react-dom && cp src/styles.css dist/styles.css",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@rickydata/design-tokens": "^0.1.0",
    "d3-force": "^3.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/d3-force": "^3.0.10",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "jsdom": "^24.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT"
}
