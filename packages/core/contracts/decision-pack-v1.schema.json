{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rickydata.org/contracts/decision-pack-v1.schema.json",
  "title": "RickyData Decision Pack v1",
  "description": "Canonical cross-repository schemas for structurally complete decision evidence. Content is observable only; hidden model reasoning is excluded.",
  "oneOf": [
    { "$ref": "#/$defs/DecisionPack" },
    { "$ref": "#/$defs/DecisionSourceReceipt" },
    { "$ref": "#/$defs/ContextDeliveryReceipt" },
    { "$ref": "#/$defs/DecisionObservation" },
    { "$ref": "#/$defs/ContentArtifactRef" }
  ],
  "$defs": {
    "Sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "ArtifactUri": {
      "type": "string",
      "pattern": "^content-artifact:sha256:[0-9a-f]{64}$"
    },
    "CanonicalGraphRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodeId", "label"],
      "properties": {
        "nodeId": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "sourceRef": { "type": "string", "minLength": 1 }
      }
    },
    "RepositorySnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner", "repository", "fullName", "remoteUrl"],
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "repository": { "type": "string", "minLength": 1 },
        "fullName": { "type": "string", "minLength": 3 },
        "remoteUrl": { "type": "string", "minLength": 1 },
        "branch": { "type": "string", "minLength": 1 },
        "commitSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
      }
    },
    "ContentArtifactRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifactId", "uri", "contentHash", "byteLength", "mediaType", "observableKind", "storage", "encryption", "chunkCount"],
      "properties": {
        "artifactId": { "type": "string", "format": "uuid" },
        "uri": { "$ref": "#/$defs/ArtifactUri" },
        "contentHash": { "$ref": "#/$defs/Sha256" },
        "byteLength": { "type": "integer", "minimum": 0 },
        "mediaType": { "type": "string", "minLength": 1 },
        "observableKind": { "type": "string", "minLength": 1 },
        "storage": { "const": "kfdb-private-kv" },
        "encryption": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scheme", "scope"],
          "properties": {
            "scheme": { "const": "kfdb-s2d" },
            "scope": { "const": "wallet-private" }
          }
        },
        "sourceRef": { "type": "string", "minLength": 1 },
        "chunkCount": { "type": "integer", "minimum": 1, "maximum": 4096 }
      }
    },
    "DecisionSourceReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["receiptKey", "source", "status", "cursorExhausted", "scanLimitHit", "returned", "unresolvedReferences", "undecryptableRecords", "droppedRecords"],
      "properties": {
        "receiptKey": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "status": { "enum": ["complete", "bounded", "incomplete", "error", "not_configured"] },
        "cursorExhausted": { "type": "boolean" },
        "scanLimitHit": { "type": "boolean" },
        "returned": { "type": "integer", "minimum": 0 },
        "totalMatched": { "type": "integer", "minimum": 0 },
        "unresolvedReferences": { "type": "integer", "minimum": 0 },
        "undecryptableRecords": { "type": "integer", "minimum": 0 },
        "droppedRecords": { "type": "integer", "minimum": 0 },
        "watermark": { "type": "string", "minLength": 1 },
        "cutoff": { "type": "string", "minLength": 1 },
        "reason": { "type": "string" },
        "artifacts": { "type": "array", "items": { "$ref": "#/$defs/ContentArtifactRef" } }
      }
    },
    "DecisionPack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["walletAddress", "packKey", "packHash", "subject", "decisionKind", "completeness", "requiredSources", "sourceReceipts", "artifacts", "createdAt"],
      "properties": {
        "contractVersion": { "const": "rickydata.decision_pack.v1" },
        "walletAddress": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
        "packKey": { "type": "string", "minLength": 1 },
        "packHash": { "$ref": "#/$defs/Sha256" },
        "subject": { "$ref": "#/$defs/CanonicalGraphRef" },
        "decisionKind": { "enum": ["wiki_change", "canvas_approval", "github_pr", "plan_review", "tool_permission", "roadmap", "other"] },
        "completeness": { "enum": ["complete", "bounded", "incomplete"] },
        "requiredSources": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "sourceReceipts": { "type": "array", "items": { "$ref": "#/$defs/DecisionSourceReceipt" } },
        "artifacts": { "type": "array", "items": { "$ref": "#/$defs/ContentArtifactRef" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "cutoff": { "type": "string", "minLength": 1 }
      }
    },
    "Omission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "reason"],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "count": { "type": "integer", "minimum": 0 }
      }
    },
    "ContextDeliveryReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deliveryKey", "session", "renderedArtifact", "interface", "coverageStatus", "omissions", "deliveredAt"],
      "properties": {
        "deliveryKey": { "type": "string", "minLength": 1 },
        "session": { "$ref": "#/$defs/CanonicalGraphRef" },
        "packId": { "type": "string", "format": "uuid" },
        "packHash": { "$ref": "#/$defs/Sha256" },
        "renderedArtifact": { "$ref": "#/$defs/ContentArtifactRef" },
        "interface": { "type": "string", "minLength": 1 },
        "coverageStatus": { "enum": ["complete", "bounded", "incomplete"] },
        "omissions": { "type": "array", "items": { "$ref": "#/$defs/Omission" } },
        "deliveredAt": { "type": "string", "format": "date-time" }
      }
    },
    "DecisionObservation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observationKey", "session", "kind", "interface", "questionArtifact", "optionsPresented", "actor", "observedAt"],
      "properties": {
        "observationKey": { "type": "string", "minLength": 1 },
        "session": { "$ref": "#/$defs/CanonicalGraphRef" },
        "packId": { "type": "string", "format": "uuid" },
        "kind": { "enum": ["ask_user", "tool_permission", "approval_gate", "roadmap", "other"] },
        "interface": { "type": "string", "minLength": 1 },
        "questionArtifact": { "$ref": "#/$defs/ContentArtifactRef" },
        "optionsArtifact": { "$ref": "#/$defs/ContentArtifactRef" },
        "rationaleArtifact": { "$ref": "#/$defs/ContentArtifactRef" },
        "optionsPresented": { "type": "array", "items": { "type": "string" } },
        "selectedOption": { "type": "string" },
        "actor": { "enum": ["human", "agent", "system"] },
        "policyRef": { "type": "string", "minLength": 1 },
        "observedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
